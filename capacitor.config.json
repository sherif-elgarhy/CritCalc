{
  "appId": "com.critcalc.app",
  "appName": "CritCalc",
  "webDir": "www",
  "bundledWebRuntime": false,
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0d1f3c"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#0d1f3c",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    }
  }
}

